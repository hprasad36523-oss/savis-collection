<script>
// ── DATA ─────────────────────────────────────────────────────────────────────
// In production, this is fetched from your backend API (managed via Telegram bot)
const COLLECTIONS = [
  {name:'🔥 BIG COMBO SALE',cta:'View All',img:'https://images.unsplash.com/photo-1483985988355-763728e1935b?w=300&q=80',href:'#'},
  {name:'Palazzo Set',cta:'View All',img:'https://images.unsplash.com/photo-1594938298603-c8148c4b4d73?w=300&q=80',href:'#'},
  {name:'Georgette Frock',cta:'View All',img:'https://images.unsplash.com/photo-1566479179817-51cf0e98c0b7?w=300&q=80',href:'#'},
  {name:'Stylish Co-Ords',cta:'View All',img:'https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?w=300&q=80',href:'#coords'},
  {name:'Elegant Sarees',cta:'View All',img:'https://images.unsplash.com/photo-1610030469983-98e550d6193c?w=300&q=80',href:'#sarees'},
  {name:'Night Gowns',cta:'View All',img:'https://images.unsplash.com/photo-1596783074918-c84cb06531ca?w=300&q=80',href:'#nightgown'},
  {name:'Trendy Kurtis',cta:'View All',img:'https://images.unsplash.com/photo-1595777457583-95e059d581b8?w=300&q=80',href:'#kurtis'},
  {name:'Feeding Dresses',cta:'View All',img:'https://images.unsplash.com/photo-1558769132-cb1aea458c5e?w=300&q=80',href:'#feeding'},
  {name:'Cotton Collection',cta:'View All',img:'https://images.unsplash.com/photo-1551488831-00ddcb6c6bd3?w=300&q=80',href:'#cotton'},
  {name:'Short Tops',cta:'View All',img:'https://images.unsplash.com/photo-1588359348347-9bc6cbbb689e?w=300&q=80',href:'#shorttops'},
  {name:'Salwars',cta:'View All',img:'https://images.unsplash.com/photo-1601924994987-69e26d50dc26?w=300&q=80',href:'#'},
  {name:'Kids Collections',cta:'View All',img:'https://images.unsplash.com/photo-1519457431-44ccd64a579b?w=300&q=80',href:'#kids'},
  {name:'Home Essentials',cta:'View All',img:'https://images.unsplash.com/photo-1505740420928-5e560c06d30e?w=300&q=80',href:'#'},
  {name:'Readymade Blouse',cta:'View All',img:'https://images.unsplash.com/photo-1469334031218-e382a71b716b?w=300&q=80',href:'#'},
];

// Product factory — generates realistic demo product entries
function makeProducts(category, names, prices, imgs, oldPrices=[], isNew=false) {
  return names.map((name,i) => ({
    id: `${category}-${i}`,
    name, category,
    price: prices[i % prices.length],
    oldPrice: oldPrices[i % oldPrices.length] || null,
    img: imgs[i % imgs.length],
    imgHover: imgs[(i+1) % imgs.length],
    badge: isNew ? 'new' : '',
    inStock: true,
  }));
}

const IMG = {
  coord: [
    'https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?w=300&q=80',
    'https://images.unsplash.com/photo-1551488831-00ddcb6c6bd3?w=300&q=80',
    'https://images.unsplash.com/photo-1595777457583-95e059d581b8?w=300&q=80',
    'https://images.unsplash.com/photo-1596783074918-c84cb06531ca?w=300&q=80',
  ],
  kurti: [
    'https://images.unsplash.com/photo-1610030469983-98e550d6193c?w=300&q=80',
    'https://images.unsplash.com/photo-1583391733956-6c78276477e2?w=300&q=80',
    'https://images.unsplash.com/photo-1549298916-b41d501d3772?w=300&q=80',
    'https://images.unsplash.com/photo-1558769132-cb1aea458c5e?w=300&q=80',
  ],
  night: [
    'https://images.unsplash.com/photo-1596783074918-c84cb06531ca?w=300&q=80',
    'https://images.unsplash.com/photo-1566479179817-51cf0e98c0b7?w=300&q=80',
    'https://images.unsplash.com/photo-1551488831-00ddcb6c6bd3?w=300&q=80',
  ],
  kids: [
    'https://images.unsplash.com/photo-1519457431-44ccd64a579b?w=300&q=80',
    'https://images.unsplash.com/photo-1518831959646-742c3a14ebf7?w=300&q=80',
    'https://images.unsplash.com/photo-1561731216-c3a4d99437d5?w=300&q=80',
  ],
  cotton: [
    'https://images.unsplash.com/photo-1595777457583-95e059d581b8?w=300&q=80',
    'https://images.unsplash.com/photo-1469334031218-e382a71b716b?w=300&q=80',
    'https://images.unsplash.com/photo-1588359348347-9bc6cbbb689e?w=300&q=80',
  ],
  saree: [
    'https://images.unsplash.com/photo-1610030469983-98e550d6193c?w=300&q=80',
    'https://images.unsplash.com/photo-1549298916-b41d501d3772?w=300&q=80',
    'https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?w=300&q=80',
  ],
};

const PRODUCTS = {
  newArrivals: [
    ...makeProducts('Co-ords',['Cotton Co-ord Set Yellow','Cotton Co-ord Set Red','Cotton Co-ord Set Brown','Cotton Co-ord Set Green','Cotton Co-ord Set Navy Blue','Cotton Co-ord Set Black'],[999,999,999,999,999,999],IMG.coord,[1299],true),
    ...makeProducts('Cotton',['Cambric Cotton Frock Forest Green','Cambric Cotton Frock Lime Green','Cambric Cotton Frock Black','Cotton Notched Collar Dress Red','Cotton Notched Collar Dress Green'],[999,999,999,999,999],IMG.cotton,[1199],true),
    ...makeProducts('Night Gown',['Pure Cotton Night Dress Brown','Pure Cotton Night Dress Green','Pure Cotton Night Dress Grey','Pure Cotton Night Dress Peach'],[750,750,750,750],IMG.night,[950],true),
  ],
  cotton: makeProducts('Cotton',['Cambric Cotton Frock Forest Green','Cambric Cotton Frock Lime Green','Cambric Cotton Frock Black','Cotton Notched Collar Red','Cotton Notched Collar Green','Cambric Frocks Peacock Blue','Cambric Frocks Steel Blue','Cotton Straight Collar Pink'],[999,999,999,999,999,999,999,999],IMG.cotton,[1199,1299],true),
  coords: makeProducts('Co-ords',['Cotton Co-ord Set Yellow','Cotton Co-ord Set Red','Cotton Co-ord Set Brown','Cotton Co-ord Set Green','Cotton Co-ord Set Navy Blue','Cotton Co-ord Set Black','Perfect Co-ord Set Green','Perfect Co-ord Set Yellow','Stylish Co-ords Purple','Stylish Co-ords Green','Stylish Co-ords Black'],[999,999,999,999,999,999,999,999,899,899,1199],IMG.coord,[1299,1199,1399],true),
  kurtis: makeProducts('Kurtis',['A Line Summer Kurti Pink','A Line Summer Kurti Black','A Line Summer Kurti Green','A Line Summer Kurti Yellow','Kalyani Cotton Anarkali Parrot Green','Kalyani Cotton Anarkali Green Blue','A Line Cotton Kurti Yellow','A Line Cotton Kurti Purple','A Line Cotton Kurti Red'],[799,799,799,799,1499,1499,799,799,799],IMG.kurti,[1099,2099],false),
  nightgown: makeProducts('Night Gown',['Pure Cotton Night Dress Brown','Pure Cotton Night Dress Green','Pure Cotton Night Dress Grey','Pure Cotton Night Dress Teal','Pure Cotton Night Dress Blush Pink','Pure Cotton Night Dress Deep Navy','Pure Cotton Night Dress Peach','Pure Cotton Night Dress Lavender','A-Line Night Gown Olive Green','A-Line Night Gown Pink','Cotton Stylish Nighty Grey'],[750,750,750,750,750,750,750,750,750,750,750],IMG.night,[950,1150],true),
  kids: makeProducts('Kids',['Cotton Embroidery Co-ord Set Green','Cotton Embroidery Co-ord Set Blue','Cotton Embroidery Co-ord Set Black','Peplum Coord Set Navy Blue','Peplum Coord Set Orange','Peplum Coord Set Pink Floral','Spun Fabric Kids Frock Black','Spun Fabric Kids Frock Floral','Boys Shirt Shorts Mauve Car','Boys Shirt Shorts Blue Stripes'],[650,650,650,650,650,650,399,399,650,650],IMG.kids,[1199,699,1025],false),
  feeding: makeProducts('Feeding',['Feeding Lounge Wear Green','Feeding Lounge Wear Black Dots','Feeding Lounge Wear Dark Navy','Feeding Lounge Wear Sea Green','Feeding Lounge Wear Royal Blue','Feeding Lounge Wear Purple','Feeding Loungewear Blood Red'],[650,650,650,650,650,650,650],IMG.coord,[850],false),
  shorttops: makeProducts('Short Tops',['V Neck Sequence Border Top Reddish Purple','V Neck Border Short Top Pink','V Neck Border Short Top Peacock Blue','Straight Decollete Top Grey','V Neck Sequence Top Black','Border Short Top Yellow'],[499,499,499,499,499,499],IMG.cotton,[800,699],false),
  sarees: makeProducts('Sarees',['Elegant Silk Saree Red','Printed Cotton Saree Blue','Designer Georgette Saree Green','Traditional Kanjeevaram Gold','Party Wear Saree Purple','Casual Cotton Saree Teal'],[1499,999,1299,2499,1799,899],IMG.saree,[2099,1499,1799,3299,2499,1299],false),
};

// ── RENDER COLLECTIONS GRID ────────────────────────────────────────────────
function renderCollections() {
  document.getElementById('collectionsGrid').innerHTML = COLLECTIONS.map(c => `
    <a href="${c.href}" class="col-card">
      <div class="col-img-wrap">
        <img src="${c.img}" alt="${c.name}" class="col-img" loading="lazy">
      </div>
      <div class="col-label">
        <div class="col-name">${c.name}</div>
        <div class="col-cta">${c.cta} →</div>
      </div>
    </a>
  `).join('');
}

// ── RENDER PRODUCT ROW ─────────────────────────────────────────────────────
function renderRow(rowId, products) {
  const el = document.getElementById(rowId);
  if (!el) return;
  el.innerHTML = products.map(p => {
    const disc = p.oldPrice ? Math.round((1 - p.price/p.oldPrice)*100) : 0;
    return `
    <div class="product-card" onclick="openProduct('${p.id}')">
      <div class="pc-img-wrap">
        <img src="${p.img}" alt="${p.name}" class="pc-img" loading="lazy">
        <img src="${p.imgHover}" alt="${p.name}" class="pc-img-hover" loading="lazy">
        <div class="pc-badges">
          ${disc ? `<span class="badge badge-off">-${disc}% OFF</span>` : ''}
          ${p.badge==='new' ? `<span class="badge badge-new">NEW</span>` : ''}
        </div>
        <div class="pc-actions">
          <button class="pc-cart-btn" onclick="event.stopPropagation();addToCart('${p.id}')">Add to Cart</button>
          <button class="pc-wish-btn" onclick="event.stopPropagation();showToast('Added to Wishlist ♡')">♡</button>
        </div>
      </div>
      <div class="pc-name">${p.name}</div>
      <div class="pc-category">${p.category}</div>
      <div class="pc-price-row">
        <span class="pc-price">₹${p.price.toLocaleString('en-IN')}</span>
        ${p.oldPrice ? `<span class="pc-old">₹${p.oldPrice.toLocaleString('en-IN')}</span>` : ''}
        ${disc ? `<span class="pc-discount">${disc}% off</span>` : ''}
      </div>
    </div>
  `}).join('');
}

function renderAll() {
  renderCollections();
  renderRow('newArrivalsRow', PRODUCTS.newArrivals);
  renderRow('cottonRow', PRODUCTS.cotton);
  renderRow('coordsRow', PRODUCTS.coords);
  renderRow('kurtisRow', PRODUCTS.kurtis);
  renderRow('nightgownRow', PRODUCTS.nightgown);
  renderRow('kidsRow', PRODUCTS.kids);
  renderRow('feedingRow', PRODUCTS.feeding);
  renderRow('shorttopsRow', PRODUCTS.shorttops);
  renderRow('sareesRow', PRODUCTS.sarees);
}

// ── HERO SLIDER ────────────────────────────────────────────────────────────
let heroIdx = 0;
const totalSlides = 3;
function heroSlide(dir) { goToSlide((heroIdx + dir + totalSlides) % totalSlides); }
function goToSlide(i) {
  heroIdx = i;
  document.getElementById('heroSlides').style.transform = `translateX(-${i * 100}%)`;
  document.querySelectorAll('.hero-dot').forEach((d,j) => d.classList.toggle('active', j===i));
}
setInterval(() => heroSlide(1), 5000);

// ── CART ──────────────────────────────────────────────────────────────────
let cart = [];
const allProducts = Object.values(PRODUCTS).flat();

function getProduct(id) { return allProducts.find(p => p.id === id); }

function addToCart(id) {
  const p = getProduct(id);
  if (!p) return;
  const ex = cart.find(c => c.id === id);
  if (ex) ex.qty++;
  else cart.push({...p, qty:1});
  updateCartUI();
  showToast(`${p.name} added to cart`);
}

function updateCartUI() {
  const count = cart.reduce((s,c) => s+c.qty, 0);
  const total = cart.reduce((s,c) => s+c.price*c.qty, 0);
  document.getElementById('cartBadge').textContent = count;
  document.getElementById('cartCountHead').textContent = count;
  const body = document.getElementById('cartBody');
  const foot = document.getElementById('cartFoot');
  if (cart.length === 0) {
    body.innerHTML = `<div class="cart-empty-msg"><div class="empty-icon">🛒</div><h4>Your cart is empty</h4><p>Add some products to get started!</p></div>`;
    foot.style.display = 'none';
  } else {
    body.innerHTML = cart.map((c,i) => `
      <div class="cart-item">
        <img src="${c.img}" alt="${c.name}" class="ci-img">
        <div class="ci-info">
          <div class="ci-name">${c.name}</div>
          <div class="ci-meta">${c.category} · ₹${c.price.toLocaleString('en-IN')}</div>
          <div class="ci-qty">
            <button class="qty-btn" onclick="changeQty(${i},-1)">−</button>
            <span>${c.qty}</span>
            <button class="qty-btn" onclick="changeQty(${i},1)">+</button>
          </div>
        </div>
        <div style="display:flex;flex-direction:column;align-items:flex-end;gap:6px;">
          <span class="ci-price">₹${(c.price*c.qty).toLocaleString('en-IN')}</span>
          <button class="ci-remove" onclick="removeFromCart(${i})">✕</button>
        </div>
      </div>`).join('');
    document.getElementById('cartTotal').textContent = '₹' + total.toLocaleString('en-IN');
    foot.style.display = 'block';
  }
}

function changeQty(i, d) {
  cart[i].qty += d;
  if (cart[i].qty <= 0) cart.splice(i, 1);
  updateCartUI();
}
function removeFromCart(i) { cart.splice(i,1); updateCartUI(); }
function toggleCart() {
  const open = document.getElementById('cartDrawer').classList.toggle('open');
  document.getElementById('overlay').classList.toggle('open');
  document.body.style.overflow = open ? 'hidden' : '';
  if (open) updateCartUI();
}
function checkout() {
  showToast('Redirecting to checkout...');
  setTimeout(() => alert('Checkout integration coming soon!\nTotal: ₹' + cart.reduce((s,c)=>s+c.price*c.qty,0).toLocaleString('en-IN')), 600);
}

// ── PRODUCT CLICK ─────────────────────────────────────────────────────────
function openProduct(id) {
  const p = getProduct(id);
  if (!p) return;
  // In production, navigate to /product/[id] page
  showToast(`Viewing: ${p.name}`);
}

// ── SEARCH ────────────────────────────────────────────────────────────────
function handleSearch(val) {
  if (!val.trim()) return;
  const matches = allProducts.filter(p => p.name.toLowerCase().includes(val.toLowerCase()) || p.category.toLowerCase().includes(val.toLowerCase()));
  // In production: show dropdown results
}

// ── TOAST ─────────────────────────────────────────────────────────────────
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2600);
}

// ── INIT ──────────────────────────────────────────────────────────────────
renderAll();
updateCartUI();

