<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SAIVI'S collection — Premium Fabrics, Made in India</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Playfair+Display:wght@400;600&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;}
:root{
  --primary:#c8102e;
  --primary-dark:#a00d24;
  --black:#1a1a1a;
  --gray:#666;
  --light:#f5f5f5;
  --border:#e8e8e8;
  --white:#fff;
  --green:#2d8c4e;
  --badge-new:#1a6fbf;
}
body{font-family:'Poppins',sans-serif;color:var(--black);background:#fff;overflow-x:hidden;}

/* ── TOP BAR ── */
.top-bar{background:var(--primary);color:#fff;text-align:center;padding:8px 1rem;font-size:12px;letter-spacing:.5px;}
.top-bar a{color:#fff;text-decoration:none;}

/* ── HEADER ── */
header{
  position:sticky;top:0;z-index:200;background:#fff;
  border-bottom:1px solid var(--border);
  box-shadow:0 2px 8px rgba(0,0,0,.06);
}
.header-inner{
  max-width:1280px;margin:0 auto;
  display:flex;align-items:center;justify-content:space-between;
  padding:12px 1.5rem;gap:1rem;
}
.logo{
  font-family:'Playfair Display',serif;
  font-size:26px;font-weight:600;color:var(--primary);
  text-decoration:none;white-space:nowrap;
  display:flex;align-items:center;gap:8px;
  letter-spacing:0.3px;
}
.logo span{font-weight:400;color:var(--black);}
.search-bar{
  flex:1;max-width:500px;
  display:flex;border:1.5px solid var(--border);border-radius:4px;overflow:hidden;
  transition:border-color .2s;
}
.search-bar:focus-within{border-color:var(--primary);}
.search-bar input{
  flex:1;padding:10px 14px;border:none;outline:none;
  font-family:'Poppins',sans-serif;font-size:14px;
}
.search-bar button{
  background:var(--primary);border:none;padding:0 18px;
  color:#fff;cursor:pointer;font-size:16px;transition:background .2s;
}
.search-bar button:hover{background:var(--primary-dark);}
.header-actions{display:flex;gap:6px;align-items:center;}
.hdr-btn{
  display:flex;flex-direction:column;align-items:center;gap:2px;
  background:none;border:none;cursor:pointer;padding:6px 10px;
  color:var(--black);font-family:'Poppins',sans-serif;
  font-size:10px;font-weight:500;text-decoration:none;
  border-radius:4px;transition:background .15s;position:relative;
  white-space:nowrap;
}
.hdr-btn:hover{background:var(--light);}
.hdr-btn .icon{font-size:20px;line-height:1;}
.cart-badge{
  position:absolute;top:4px;right:8px;
  background:var(--primary);color:#fff;
  font-size:9px;font-weight:700;
  width:16px;height:16px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
}

/* ── NAV ── */
nav{background:#fff;border-bottom:1px solid var(--border);}
.nav-inner{
  max-width:1280px;margin:0 auto;
  display:flex;align-items:center;gap:0;
  overflow-x:auto;scrollbar-width:none;
}
.nav-inner::-webkit-scrollbar{display:none;}
.nav-link{
  display:block;padding:12px 18px;
  font-size:13px;font-weight:500;color:var(--black);
  text-decoration:none;white-space:nowrap;
  border-bottom:2px solid transparent;
  transition:color .2s,border-color .2s;
}
.nav-link:hover,.nav-link.active{color:var(--primary);border-bottom-color:var(--primary);}

/* ── HERO SLIDER ── */
.hero{position:relative;overflow:hidden;background:#f9f0f2;}
.hero-slides{display:flex;transition:transform .5s ease;}
.hero-slide{
  min-width:100%;position:relative;
  display:grid;grid-template-columns:1fr 1fr;
  align-items:center;min-height:420px;
}
.hero-slide.reverse{direction:rtl;}
.hero-slide.reverse>*{direction:ltr;}
.hero-img{width:100%;height:100%;min-height:420px;object-fit:cover;}
.hero-content{
  padding:3rem 4rem;
}
.hero-tag{
  display:inline-block;
  background:var(--primary);color:#fff;
  font-size:11px;letter-spacing:2px;text-transform:uppercase;
  padding:5px 14px;margin-bottom:1rem;font-weight:600;
}
.hero-title{
  font-family:'Playfair Display',serif;
  font-size:clamp(28px,4vw,46px);font-weight:600;
  line-height:1.15;margin-bottom:1rem;color:var(--black);
}
.hero-title em{color:var(--primary);font-style:normal;}
.hero-sub{font-size:14px;color:var(--gray);line-height:1.7;margin-bottom:1.75rem;max-width:380px;}
.hero-cta{
  display:inline-flex;align-items:center;gap:8px;
  background:var(--primary);color:#fff;
  padding:13px 28px;font-size:13px;font-weight:600;
  text-decoration:none;letter-spacing:.5px;
  border:2px solid var(--primary);transition:all .2s;
}
.hero-cta:hover{background:transparent;color:var(--primary);}
.hero-dots{
  position:absolute;bottom:1.25rem;left:50%;transform:translateX(-50%);
  display:flex;gap:8px;
}
.hero-dot{
  width:8px;height:8px;border-radius:50%;
  background:rgba(0,0,0,.2);border:none;cursor:pointer;transition:background .2s;
}
.hero-dot.active{background:var(--primary);}
.hero-arrow{
  position:absolute;top:50%;transform:translateY(-50%);
  background:rgba(255,255,255,.9);border:1px solid var(--border);
  width:40px;height:40px;border-radius:50%;
  cursor:pointer;font-size:18px;display:flex;align-items:center;justify-content:center;
  transition:background .2s;z-index:5;
}
.hero-arrow:hover{background:#fff;}
.hero-arrow.prev{left:1rem;}
.hero-arrow.next{right:1rem;}

/* ── TRUST STRIP ── */
.trust-strip{
  background:#fff;border-bottom:1px solid var(--border);
  padding:1rem 1.5rem;
}
.trust-inner{
  max-width:1280px;margin:0 auto;
  display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;
}
.trust-item{
  display:flex;align-items:center;gap:10px;
  justify-content:center;
}
.trust-icon{font-size:24px;}
.trust-text strong{display:block;font-size:13px;font-weight:600;}
.trust-text span{font-size:11px;color:var(--gray);}

/* ── SECTION COMMON ── */
.section{padding:2.5rem 0;}
.section-inner{max-width:1280px;margin:0 auto;padding:0 1.5rem;}
.section-head{
  display:flex;align-items:center;justify-content:space-between;
  margin-bottom:1.5rem;
  border-left:4px solid var(--primary);
  padding-left:12px;
}
.section-title{
  font-family:'Playfair Display',serif;
  font-size:22px;font-weight:600;color:var(--black);
}
.view-all{
  font-size:12px;font-weight:600;color:var(--primary);
  text-decoration:none;letter-spacing:.5px;text-transform:uppercase;
  border:1.5px solid var(--primary);padding:7px 16px;
  transition:all .2s;white-space:nowrap;
}
.view-all:hover{background:var(--primary);color:#fff;}

/* ── COLLECTIONS GRID ── */
.collections-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(160px,1fr));
  gap:1rem;
}
.col-card{
  position:relative;overflow:hidden;cursor:pointer;
  border-radius:6px;background:var(--light);
  border:1px solid var(--border);
  transition:transform .25s,box-shadow .25s;
  text-decoration:none;display:block;
}
.col-card:hover{transform:translateY(-4px);box-shadow:0 8px 24px rgba(0,0,0,.1);}
.col-img-wrap{aspect-ratio:3/4;overflow:hidden;}
.col-img{width:100%;height:100%;object-fit:cover;transition:transform .5s;}
.col-card:hover .col-img{transform:scale(1.06);}
.col-label{
  padding:10px 10px;text-align:center;
}
.col-name{font-size:13px;font-weight:600;color:var(--black);margin-bottom:2px;}
.col-cta{font-size:11px;color:var(--primary);font-weight:500;}

/* ── PRODUCTS ROW (horizontal scroll) ── */
.products-scroll{
  display:flex;gap:1rem;
  overflow-x:auto;padding-bottom:8px;
  scrollbar-width:thin;scrollbar-color:var(--border) transparent;
}
.products-scroll::-webkit-scrollbar{height:4px;}
.products-scroll::-webkit-scrollbar-thumb{background:var(--border);}

/* ── PRODUCT CARD ── */
.product-card{
  min-width:200px;max-width:200px;
  cursor:pointer;flex-shrink:0;
  transition:transform .25s;
  text-decoration:none;color:inherit;
  display:block;
}
.product-card:hover{transform:translateY(-3px);}
.pc-img-wrap{
  position:relative;overflow:hidden;
  background:var(--light);aspect-ratio:2/3;border-radius:4px;
  margin-bottom:10px;
}
.pc-img,.pc-img-hover{
  width:100%;height:100%;object-fit:cover;
  position:absolute;inset:0;transition:opacity .4s;
}
.pc-img-hover{opacity:0;}
.product-card:hover .pc-img{opacity:0;}
.product-card:hover .pc-img-hover{opacity:1;}
.pc-badges{
  position:absolute;top:8px;left:8px;
  display:flex;flex-direction:column;gap:4px;z-index:1;
}
.badge{
  font-size:10px;font-weight:700;padding:3px 8px;
  letter-spacing:.5px;
}
.badge-off{background:var(--primary);color:#fff;}
.badge-new{background:var(--badge-new);color:#fff;}
.pc-actions{
  position:absolute;bottom:-48px;left:0;right:0;
  display:flex;gap:0;transition:bottom .25s ease;
  z-index:2;
}
.product-card:hover .pc-actions{bottom:0;}
.pc-cart-btn{
  flex:1;background:rgba(26,26,26,.9);color:#fff;
  border:none;padding:12px 8px;font-size:11px;font-weight:600;
  letter-spacing:.5px;cursor:pointer;font-family:'Poppins',sans-serif;
  transition:background .2s;
}
.pc-cart-btn:hover{background:var(--primary);}
.pc-wish-btn{
  background:rgba(255,255,255,.9);border:none;
  padding:12px 14px;font-size:16px;cursor:pointer;
  transition:background .2s;
}
.pc-wish-btn:hover{background:#fff;}
.pc-name{font-size:13px;font-weight:500;color:var(--black);margin-bottom:4px;line-height:1.3;}
.pc-category{font-size:11px;color:var(--gray);margin-bottom:6px;}
.pc-price-row{display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.pc-price{font-size:14px;font-weight:700;color:var(--black);}
.pc-old{font-size:12px;color:var(--gray);text-decoration:line-through;}
.pc-discount{font-size:11px;font-weight:600;color:var(--green);}

/* ── PROMO BANNER ── */
.promo-banner{
  background:linear-gradient(135deg,#1a1a1a 0%,#3d0010 100%);
  padding:3rem 1.5rem;text-align:center;
}
.promo-banner h2{
  font-family:'Playfair Display',serif;
  font-size:clamp(24px,3.5vw,40px);font-weight:600;color:#fff;
  margin-bottom:.75rem;
}
.promo-banner p{font-size:15px;color:rgba(255,255,255,.7);margin-bottom:1.75rem;}
.promo-cta{
  display:inline-flex;align-items:center;gap:8px;
  background:var(--primary);color:#fff;
  padding:14px 36px;font-size:14px;font-weight:600;
  text-decoration:none;border:2px solid var(--primary);
  transition:all .2s;
}
.promo-cta:hover{background:transparent;border-color:#fff;color:#fff;}

/* ── CART DRAWER ── */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:400;opacity:0;pointer-events:none;transition:opacity .3s;}
.overlay.open{opacity:1;pointer-events:all;}
.cart-drawer{
  position:fixed;top:0;right:0;bottom:0;width:380px;
  background:#fff;z-index:401;
  transform:translateX(100%);transition:transform .35s cubic-bezier(.4,0,.2,1);
  display:flex;flex-direction:column;
}
.cart-drawer.open{transform:none;}
.cart-head{
  display:flex;align-items:center;justify-content:space-between;
  padding:1.25rem 1.5rem;border-bottom:1px solid var(--border);
}
.cart-head h3{font-size:18px;font-weight:600;}
.close-btn{background:none;border:none;font-size:22px;cursor:pointer;color:var(--gray);transition:color .2s;}
.close-btn:hover{color:var(--black);}
.cart-body{flex:1;overflow-y:auto;padding:1.25rem 1.5rem;}
.cart-empty-msg{
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  height:100%;gap:1rem;color:var(--gray);text-align:center;
}
.cart-empty-msg .empty-icon{font-size:52px;opacity:.3;}
.cart-item{display:flex;gap:12px;padding:12px 0;border-bottom:1px solid var(--border);}
.ci-img{width:64px;height:80px;object-fit:cover;background:var(--light);flex-shrink:0;border-radius:3px;}
.ci-info{flex:1;}
.ci-name{font-size:13px;font-weight:500;margin-bottom:3px;line-height:1.3;}
.ci-meta{font-size:11px;color:var(--gray);margin-bottom:8px;}
.ci-qty{display:flex;align-items:center;gap:8px;}
.qty-btn{width:24px;height:24px;border:1px solid var(--border);background:none;cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center;transition:background .15s;}
.qty-btn:hover{background:var(--light);}
.ci-price{font-size:13px;font-weight:600;white-space:nowrap;}
.ci-remove{background:none;border:none;cursor:pointer;color:var(--gray);font-size:16px;align-self:flex-start;transition:color .2s;}
.ci-remove:hover{color:var(--primary);}
.cart-foot{padding:1.25rem 1.5rem;border-top:1px solid var(--border);}
.cart-subtotal{display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;}
.cart-subtotal span:first-child{font-size:14px;color:var(--gray);}
.cart-subtotal strong{font-size:18px;font-weight:700;}
.checkout-btn{
  width:100%;background:var(--primary);color:#fff;border:none;
  padding:15px;font-size:14px;font-weight:600;font-family:'Poppins',sans-serif;
  cursor:pointer;letter-spacing:.5px;transition:background .2s;margin-bottom:10px;
}
.checkout-btn:hover{background:var(--primary-dark);}
.continue-btn{
  width:100%;background:none;border:1.5px solid var(--border);
  padding:13px;font-size:13px;font-weight:500;font-family:'Poppins',sans-serif;
  cursor:pointer;color:var(--black);transition:border-color .2s;
}
.continue-btn:hover{border-color:var(--black);}

/* ── TOAST ── */
.toast{
  position:fixed;bottom:1.5rem;left:50%;transform:translateX(-50%) translateY(10px);
  background:var(--black);color:#fff;padding:12px 24px;font-size:13px;font-weight:500;
  border-radius:4px;z-index:500;opacity:0;transition:all .3s;pointer-events:none;
  white-space:nowrap;
}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0);}

/* ── FOOTER ── */
footer{background:#1a1a1a;color:rgba(255,255,255,.7);padding:3rem 1.5rem 1.5rem;}
.footer-grid{max-width:1280px;margin:0 auto;display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:2.5rem;margin-bottom:2.5rem;}
.footer-brand .logo{color:#fff;font-size:22px;}
.footer-about{font-size:13px;line-height:1.7;margin-top:1rem;max-width:260px;}
.footer-socials{display:flex;gap:10px;margin-top:1.25rem;}
.social{width:34px;height:34px;border:1px solid rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,.6);text-decoration:none;font-size:14px;border-radius:3px;transition:all .2s;}
.social:hover{border-color:var(--primary);color:var(--primary);}
.footer-col h4{font-size:13px;font-weight:600;color:#fff;margin-bottom:1rem;text-transform:uppercase;letter-spacing:1px;}
.footer-col ul{list-style:none;}
.footer-col li{margin-bottom:.6rem;}
.footer-col a{font-size:13px;color:rgba(255,255,255,.6);text-decoration:none;transition:color .2s;}
.footer-col a:hover{color:var(--primary);}
.footer-bottom{max-width:1280px;margin:0 auto;padding-top:1.5rem;border-top:1px solid rgba(255,255,255,.1);display:flex;justify-content:space-between;align-items:center;font-size:12px;}

/* ── MARQUEE ── */
.marquee-wrap{background:var(--black);overflow:hidden;padding:10px 0;}
.marquee{display:flex;gap:0;white-space:nowrap;animation:marquee 30s linear infinite;}
.marquee span{font-size:12px;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,.7);padding:0 2rem;}
.marquee span.dot{color:var(--primary);padding:0;}
@keyframes marquee{from{transform:translateX(0);}to{transform:translateX(-50%);}}

/* ── WHATSAPP ── */
.wa-btn{
  position:fixed;bottom:1.5rem;right:1.5rem;z-index:150;
  background:#25D366;color:#fff;width:52px;height:52px;
  border-radius:50%;display:flex;align-items:center;justify-content:center;
  font-size:26px;text-decoration:none;
  box-shadow:0 4px 16px rgba(37,211,102,.4);
  transition:transform .2s,box-shadow .2s;
}
.wa-btn:hover{transform:scale(1.1);box-shadow:0 6px 24px rgba(37,211,102,.5);}

/* ── RESPONSIVE ── */
@media(max-width:900px){
  .hero-slide{grid-template-columns:1fr;min-height:auto;}
  .hero-img{display:none;}
  .hero-content{padding:2rem 1.5rem;}
  .trust-inner{grid-template-columns:repeat(2,1fr);}
  .footer-grid{grid-template-columns:1fr 1fr;}
  .collections-grid{grid-template-columns:repeat(auto-fill,minmax(130px,1fr));}
}
@media(max-width:600px){
  .header-inner{flex-wrap:wrap;}
  .search-bar{order:3;flex:0 0 100%;}
  .trust-inner{grid-template-columns:1fr 1fr;}
  .footer-grid{grid-template-columns:1fr;}
  .product-card{min-width:160px;max-width:160px;}
}
</style>
</head>
<body>

<!-- TOP BAR -->
<div class="top-bar">
  🚚 Free Shipping on orders above ₹599 &nbsp;|&nbsp; ✨ New arrivals every week &nbsp;|&nbsp; 📞 <a href="tel:+919876543210">+91 98765 43210</a>
</div>

<!-- HEADER -->
<header>
  <div class="header-inner">
    <a href="#" class="logo">
      <img src="/logo.png" alt="Saivi Collections Logo" style="height:38px;width:auto;object-fit:contain;margin-right:8px;flex-shrink:0;border-radius:4px">
      SAIVI'S <span>collection</span>
    </a>
    <div class="search-bar">
      <input type="text" placeholder="Search for products, categories..." id="searchInput" oninput="handleSearch(this.value)">
      <button>🔍</button>
    </div>
    <div class="header-actions">
      <a href="#" class="hdr-btn">
        <span class="icon">👤</span>
        <span>Account</span>
      </a>
      <a href="#" class="hdr-btn">
        <span class="icon">❤️</span>
        <span>Wishlist</span>
      </a>
      <button class="hdr-btn" onclick="toggleCart()">
        <span class="icon">🛒</span>
        <span>Cart</span>
        <span class="cart-badge" id="cartBadge">0</span>
      </button>
    </div>
  </div>
</header>

<!-- NAV -->
<nav>
  <div class="nav-inner">
    <a href="#" class="nav-link active" onclick="scrollTo('#collections')">Kids Collections</a>
    <a href="#" class="nav-link" onclick="scrollTo('#collections')">Home Essentials</a>
    <a href="#" class="nav-link" onclick="scrollTo('#coords')">Co Ords</a>
    <a href="#" class="nav-link" onclick="scrollTo('#cotton')">Cotton Collection</a>
    <a href="#" class="nav-link" onclick="scrollTo('#feeding')">Feeding Dress</a>
    <a href="#" class="nav-link" onclick="scrollTo('#kurtis')">Kurtis</a>
    <a href="#" class="nav-link" onclick="scrollTo('#nightgown')">Night Gown</a>
    <a href="#" class="nav-link" onclick="scrollTo('#sarees')">Sarees</a>
    <a href="#" class="nav-link">Contact Us</a>
  </div>
</nav>

<!-- HERO SLIDER -->
<div class="hero">
  <button class="hero-arrow prev" onclick="heroSlide(-1)">‹</button>
  <button class="hero-arrow next" onclick="heroSlide(1)">›</button>
  <div class="hero-slides" id="heroSlides">
    <!-- Slide 1 -->
    <div class="hero-slide">
      <div class="hero-content">
        <div class="hero-tag">🔥 Big Combo Sale is Live</div>
        <h1 class="hero-title">Premium Fabrics<br><em>Made in India,</em><br>Made for You</h1>
        <p class="hero-sub">Your favourite styles are now in combo offers at unbelievable prices. More styles · More savings · More reasons to shop.</p>
        <a href="#new-arrivals" class="hero-cta">View All Collections →</a>
      </div>
      <img src="https://images.unsplash.com/photo-1610030469983-98e550d6193c?w=700&q=80" alt="Sale" class="hero-img">
    </div>
    <!-- Slide 2 -->
    <div class="hero-slide">
      <div class="hero-content">
        <div class="hero-tag">New Arrival</div>
        <h1 class="hero-title">Elegant Cotton<br><em>Co-ords</em><br>You'll Love</h1>
        <p class="hero-sub">Effortlessly chic cotton co-ord sets in fresh shades. Comfort meets style for every occasion.</p>
        <a href="#coords" class="hero-cta">Shop Co-ords →</a>
      </div>
      <img src="https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?w=700&q=80" alt="Co-ords" class="hero-img">
    </div>
    <!-- Slide 3 -->
    <div class="hero-slide">
      <div class="hero-content">
        <div class="hero-tag">Trending</div>
        <h1 class="hero-title">Breathable<br><em>Night Gowns</em><br>for Restful Nights</h1>
        <p class="hero-sub">Soft fabrics, easy fits, and soothing styles designed for total comfort and relaxed evenings.</p>
        <a href="#nightgown" class="hero-cta">Shop Night Gowns →</a>
      </div>
